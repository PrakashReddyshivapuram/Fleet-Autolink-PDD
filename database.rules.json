{
  "rules": {
    "liveLocations": {
      "$vehicleId": {
        ".read": "auth != null",
        ".write": "auth != null && (
          !newData.exists() ||
          newData.child('driverId').val() === auth.uid
        )"
      }
    },
    "emergencyAlerts": {
      "$driverId": {
        ".read": "auth != null",
        ".write": "auth != null && $driverId === auth.uid"
      }
    }
  }
}
