{
  "expo": {
    "name": "Fleet AutoLink",
    "slug": "fleet-autolink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fleetautolink.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.fleetautolink.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Fleet AutoLink needs location access to share your position during trips.",
          "locationWhenInUsePermission": "Fleet AutoLink needs location access to share your position during trips."
        }
      ]
    ],
    "scheme": "fleetautolink",
    "experiments": {
      "typedRoutes": true
    }
  }
}
